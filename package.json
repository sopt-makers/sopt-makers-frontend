{
  "name": "sopt-makers-frontend",
  "private": true,
  "packageManager": "yarn@4.1.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "apps/*/packages/*"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:crew": "turbo run dev --filter=crew",
    "dev:playground": "turbo run dev --filter=playground",
    "build:crew": "turbo run build --filter=crew",
    "build:playground": "turbo run build --filter=playground",
    "deploy": "turbo deploy",
    "check": "turbo lint typecheck stylelint test:ci",
    "update-mds": "yarn up @sopt-makers/colors@latest @sopt-makers/fonts@latest @sopt-makers/playground-common@latest @sopt-makers/ui@latest @sopt-makers/icons@latest",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "prettier:fix": "turbo prettier -- --write",
    "clean": "turbo clean"
  },
  "dependencies": {
    "axios": "^1.1.3",
    "dayjs": "^1.11.6",
    "immer": "^10.0.4",
    "nanoid": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.43.9",
    "zod": "^3.20.6"
  },
  "devDependencies": {
    "@sopt-makers/eslint-config": "workspace:*",
    "@sopt-makers/prettier-config": "workspace:*",
    "@types/node": "18.8.3",
    "@types/react": "18.0.21",
    "@types/react-dom": "18.0.6",
    "prettier": "^3.8.1",
    "storybook": "^7.6.20",
    "turbo": "^1.12.0",
    "typescript": "^4.9.5",
    "wrangler": "^3.0.0"
  },
  "resolutions": {
    "@types/react": "18.0.21",
    "@types/react-dom": "18.0.6",
    "zod": "3.25.76",
    "react-hook-form": "7.43.9",
    "stylelint-order": "6.0.4",
    "sharp": "0.33.5"
  }
}
